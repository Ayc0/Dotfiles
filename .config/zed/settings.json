// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "cli_default_open_behavior": "new_window",
    "terminal": {
        "font_size": 12.0
    },
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "sticky_scroll": {
        "enabled": true,
    },
    "minimap": {
        "show": "never",
    },
    "max_tabs": 10,
    "confirm_quit": true,
    "buffer_font_family": "FiraCode Nerd Font",
    "file_types": {
        "ignore": [".stow-local-ignore"],
    },
    "auto_install_extensions": {
        "html": true,
        "night-owlz": true,
        "tsgo": true,
        "vscode-light-modern": true,
    },
    "colorize_brackets": true,
    "linked_edits": true,
    "show_whitespaces": "all",
    "show_edit_predictions": true,
    "ensure_final_newline_on_save": true,
    "wrap_guides": [120],
    "preferred_line_length": 120,
    "soft_wrap": "bounded",
    "hard_tabs": false,
    "tab_size": 4,
    "base_keymap": "VSCode",
    "project_panel": {
        "scrollbar": {
            "horizontal_scroll": false
        },
        "indent_size": 10.0,
        "dock": "left",
    },
    "outline_panel": {
        "button": false,
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "agent": {
        "button": false,
        "enabled": false,
        "dock": "right",
        "favorite_models": [],
        "model_parameters": [],
    },
    "git_panel": {
        "dock": "left",
        "tree_view": true,
    },
    "ui_font_size": 15.0,
    "buffer_font_size": 12.0,
    "theme": {
        "mode": "system",
        "light": "VSCode Light Modern",
        "dark": "Night Owl Dark",
    },
}
